# Nova AI - Environment Variables
# 环境变量名必须与 server/_core/env.ts 中的 process.env.XXX 一致

# === 必填：LLM 配置（聊天核心，不配则聊天功能不可用） ===
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=

# === 可选：OAuth & 用户系统（不配则仅 OAuth 登录功能不可用，聊天正常） ===
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
JWT_SECRET=change-me-to-a-random-string

# === 可选：MySQL 数据库（不配则用户持久化不可用，聊天正常） ===
DATABASE_URL=