# =============================================================
# Nova AI - Environment Variables
# =============================================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
#
# =============================================================
# 必填：LLM 配置（聊天核心）
# =============================================================
# 不配这 3 个变量，聊天功能完全不可用

# LLM API 地址（OpenAI 兼容格式）
# 示例: https://api.deepseek.com/v1/chat/completions
# 示例: https://api.openai.com/v1/chat/completions
LLM_API_URL=https://api.deepseek.com/v1/chat/completions

# LLM API Key（从你的 LLM 提供商获取）
LLM_API_KEY=sk-your-api-key-here

# 模型名称
# DeepSeek: deepseek-chat 或 deepseek-reasoner
# OpenAI: gpt-4o / gpt-4-turbo
# 其他: 参考 README 中的模型列表
LLM_MODEL=deepseek-chat

# =============================================================
# 可选：OAuth 登录 & 用户系统
# =============================================================
# 不配影响：OAuth 登录不可用，但聊天功能完全正常
# 需要配合 MySQL（DATABASE_URL）才能持久化用户数据

# OAuth 服务端 URL
OAUTH_SERVER_URL=

# OAuth 应用 ID
VITE_APP_ID=

# 管理员 Open ID
OWNER_OPEN_ID=

# JWT Cookie 加密密钥（至少 32 字符随机字符串）
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# =============================================================
# 可选：MySQL 数据库
# =============================================================
# 不配影响：用户数据不持久化，但聊天功能完全正常
# 格式: mysql://用户名:密码@主机:端口/数据库名

DATABASE_URL=

# =============================================================
# 可选：服务端口
# =============================================================
# 默认 3000，冲突时自动递增寻找可用端口

PORT=3000
