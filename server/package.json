{
  "name": "nova-ai-girlfriend-backend",
  "version": "1.0.0",
  "description": "Nova AI Girlfriend - Backend API Server",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch _core/index.ts",
    "build": "esbuild _core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=../dist",
    "start": "NODE_ENV=production node ../dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "cookie": "^1.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "express": "^4.22.1",
    "jose": "6.1.0",
    "mysql2": "^3.16.0",
    "superjson": "^1.13.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.25.12",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  }
}
